# ============================================================
# Elaxtra Outreach System — Environment Configuration
# Copy this file to .env and fill in your values
#
# On Railway: PORT is injected automatically — do NOT set it.
# Set all other vars in the Railway dashboard (Settings → Variables).
# DATABASE_URL is auto-populated when you link the Postgres service.
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- AgentMail ---
AGENTMAIL_API_KEY=am_us_817e72cde835a1c6491de18876cf619a6797fcbb5987a942d0fdbe465fccffc7
AGENTMAIL_INBOX_ADDRESS=elaxtra@agentmail.to
AGENTMAIL_WEBHOOK_SECRET=whsec_...

# --- MCP Server URLs (fixed, rarely change) ---
MCP_HUBSPOT_URL=https://mcp.hubspot.com/anthropic
MCP_APOLLO_URL=https://mcp.apollo.io/mcp
MCP_APIFY_URL=https://mcp.apify.com
MCP_MS365_URL=https://microsoft365.mcp.claude.com/mcp
MCP_AGENTMAIL_URL=https://mcp.agentmail.to

# --- HubSpot ---
HUBSPOT_PORTAL_ID=45774781

# --- BCC on ALL outgoing emails (hard requirement) ---
BCC_EMAIL=andrew.burgert@elaxtra.com
SIGNER_NAME=Andrew Burgert
SIGNER_TITLE=Partner, Elaxtra Advisors

# --- Database ---
DATABASE_URL=postgresql://postgres:abc123@monorail.proxy.rlwy.net:12345/railway

# --- Rate Limiting ---
MAX_EMAILS_PER_DAY=25
MAX_EMAILS_PER_HOUR=5
MIN_DELAY_BETWEEN_EMAILS_SECONDS=120
OUTREACH_BATCH_SIZE=10

# --- Concurrency ---
MAX_CONCURRENT_AGENT_SESSIONS=5

# --- Scheduling ---
OUTREACH_CRON_HOUR=9,13,17
OUTREACH_CRON_DAY_OF_WEEK=mon-fri
OUTREACH_TIMEZONE=America/New_York

# --- Models ---
COMPOSER_MODEL=claude-sonnet-4-6
RESPONDER_MODEL=claude-sonnet-4-6
SCHEDULER_MODEL=claude-sonnet-4-6

# --- File Paths ---
CONTACTS_EXCEL_PATH=./data/contacts.xlsx
COMPANY_PROFILE_PDF_PATH=./docs/elaxtra_company_profile.pdf

# --- Persisted setup IDs (populated by `python -m src.main setup`) ---
# These identify the agents, environment, and vault you created ONCE.
# Do not edit by hand — the setup command writes them.
COMPOSER_AGENT_ID=
COMPOSER_AGENT_VERSION=
RESPONDER_AGENT_ID=
RESPONDER_AGENT_VERSION=
SCHEDULER_AGENT_ID=
SCHEDULER_AGENT_VERSION=
ENVIRONMENT_ID=
VAULT_ID=
COMPANY_PROFILE_FILE_ID=
AGENTMAIL_INBOX_ID=

# --- Server ---
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
PUBLIC_WEBHOOK_URL=https://your-public-domain.example.com

# --- Mode ---
DRY_RUN=false
LOG_LEVEL=INFO
